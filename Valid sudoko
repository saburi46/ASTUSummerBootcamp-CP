class Solution:
    def isValidSudoku(self, board: List[List[str]]) -> bool:
        row = [set() for i in range(9)]
        column = [set() for i in range(9)]
        boxes = [set() for i in range (9)]
        for c in range(9):
            for r in range(9):
                val = board[r][c]
                if val == ".":
                    continue
                box =((r//3)*3 + c//3)
                if (val in row[r] or val in column[c] or val in boxes[box]):
                    return False
                row[r].add(val)
                column[c].add(val)
                boxes[box].add(val)
        return True

